# Provider: deepseek | gemini (default: gemini)
LLM_PROVIDER=gemini

# Model name (optional, uses provider default if omitted)
# deepseek: deepseek-chat | anthropic: claude-sonnet-4-6 | openai: gpt-4o | gemini: gemini-2.5-flash
LLM_MODEL=gemini-2.5-flash

# API keys (only the one matching LLM_PROVIDER is required)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres_agent_attendance
